# Copy this file to .env.local and enter your Azure AI Foundry values there.
# Keep these names WITHOUT a VITE_ prefix so they are never bundled into browser JavaScript.
AZURE_FOUNDRY_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your-project
AZURE_FOUNDRY_API_KEY=replace-with-your-key
AZURE_FOUNDRY_DEPLOYMENT=Phi-4
AZURE_FOUNDRY_API_VERSION=2024-05-01-preview
AZURE_FOUNDRY_TIMEOUT_MS=22000
AZURE_FOUNDRY_MAX_INPUT_CHARS=8000

# Optional. Leave empty for Azure AI Foundry services.ai.azure.com and Azure OpenAI openai.azure.com.
# Use this only if Azure gives you a special custom chat completions path.
# Example: /models/chat/completions?api-version=2024-05-01-preview
AZURE_FOUNDRY_API_PATH=

# Optional: api-key, authorization, or both. Most Azure OpenAI-style deployments use api-key.
AZURE_FOUNDRY_AUTH_HEADER=api-key

# Optional. Add a Bing Search v7 key if you want source snippets for the resource cards.
# Without this, InsightForge returns useful Bing search links from Phi-4 resource queries.
BING_SEARCH_ENDPOINT=https://api.bing.microsoft.com/v7.0/search
BING_SEARCH_API_KEY=

# Local API server
PORT=8787
